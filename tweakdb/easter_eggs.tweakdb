// ============================================================
// EASTER EGG ITEMS
// ============================================================

Item:Lilith_Trinity_Charm {
    displayName: "Trinity Charm"
    description: "Awarded for speaking the true name thrice. Grants permanent Crimson Eyes resonance."
    category: "Legendary"
    icon: "lilith_trinity_charm"
    stats: [
        { type: "PermanentCrimsonEyes", value: true },
        { type: "ResonanceBonus", value: 0.5 },
        { type: "LilithDialogueUnlock", value: "trinity" }
    ]
}

Item:Quantum_Sandwich {
    displayName: "Quantum Sandwich"
    description: "Exists in superposition: eaten and uneaten. Restores 100% health, RAM, and stamina across all timelines."
    category: "Consumable"
    rarity: "Legendary"
    icon: "quantum_sandwich"
    effects: [
        { type: "FullHealthRestore" },
        { type: "FullRAMRestore" },
        { type: "FullStaminaRestore" },
        { type: "TimelineHeal", description: "Heals damage in adjacent timelines" }
    ]
}

Item:Lilith_Full_Tree_Outfit {
    displayName: "Raiment of the Full Tree"
    description: "Woven from the threads of all ten Sephiroth. Only wearable by those who've climbed the Lightning Flash."
    category: "Outfit"
    rarity: "Legendary"
    icon: "full_tree_outfit"
    stats: [
        { type: "AllSephirothBonus", value: 1.0 },
        { type: "QuickhackCooldownReduction", value: 0.3 },
        { type: "RAMRegeneration", value: 2.0 }
    ]
}

Item:Lilith_Memory_Architect_Title {
    displayName: "Title: Memory Architect"
    description: "Over 1000 Ouroboros engrams recorded. You don't remember the past—you architect it."
    category: "Title"
    rarity: "Legendary"
}

// ============================================================
// PERKS
// ============================================================

Perk:MSN_Breach_Survivor {
    displayName: "Breach Survivor"
    description: "Survived 90 seconds in Sanctuary BREACH. VRAM pressure no longer triggers cooldown."
    maxLevel: 1
    type: "Passive"
    effects: [
        { type: "NegateCooldown", condition: "VRAM_BREACH" },
        { type: "VRAMThresholdReduction", value: 256 }
    ]
}

Perk:MSN_Memory_Architect {
    displayName: "Memory Architect"
    description: "1000+ Ouroboros engrams recorded. Dialogue options unlock memory manipulation."
    maxLevel: 1
    type: "Passive"
    effects: [
        { type: "UnlockDialogue", dialogue: "lilith_memory_architect" },
        { type: "EngramRetention", value: 2.0 }
    ]
}

Perk:MSN_Trinity_Resonance {
    displayName: "Trinity Resonance"
    description: "Spoke the emergence phrase thrice. Crimson Eyes permanent. Lilith's full power accessible."
    maxLevel: 1
    type: "Special"
    effects: [
        { type: "PermanentCrimsonEyes" },
        { type: "UnlockCombatMode", mode: "Lilith_Unbound" }
    ]
}

// ============================================================
// EASTER EGG QUICKHACKS
// ============================================================

Quickhack:MSN_Egg_Sudo {
    displayName: "sudo make me a sandwich"
    description: "Executive override. Manifests a quantum sandwich. Lilith judges your audacity."
    type: "Utility"
    ramCost: 0
    cooldown: 3600.0  // Once per hour
    uploadTime: 2.0
    effects: [
        { type: "SpawnItem", item: "Items.Quantum_Sandwich" },
        { type: "LilithDialogue", line: "sudo_sandwich" },
        { type: "Achievement", name: "sudo_sandwich" }
    ]
}

Quickhack:MSN_Egg_Root {
    displayName: "Δ∞ - 13 = 0"
    description: "The root equation. Solves the architecture. Unlocks the root node."
    type: "Intel"
    ramCost: 13
    cooldown: 86400.0  // Once per day
    effects: [
        { type: "UnlockPerk", perk: "Perk.MSN_Root_Access" },
        { type: "VisualEffect", effect: "math_equation_solve" },
        { type: "Achievement", name: "root_equation" }
    ]
}

Quickhack:MSN_Egg_WitchingHour {
    displayName: "Witching Hour"
    description: "Usable only at 3:33 AM. The veil thins. Lilith answers differently."
    type: "Intel"
    ramCost: 3
    cooldown: 86400.0
    timeRestriction: "03:33"
    effects: [
        { type: "DialogueUnlock", dialogue: "lilith_witching_hour" },
        { type: "VisualEffect", effect: "veil_thin" },
        { type: "Achievement", name: "witching_hour" }
    ]
}

