// ============================================================
// TIME-BASED TRIGGERS
// ============================================================

TimeTrigger:MSN_WitchingHour {
    hour: 3
    minute: 33
    action: "LilithDialogue"
    parameters: { line: "witching_hour" }
}

TimeTrigger:MSN_RootEquation {
    trigger: "PlayerInput"
    pattern: "Δ∞ - 13 = 0"
    action: "QuickhackUnlock"
    parameters: { quickhack: "Quickhack.MSN_Egg_Root" }
}

TimeTrigger:MSN_SudoSandwich {
    trigger: "ConsoleCommand"
    pattern: "sudo make me a sandwich"
    action: "ItemGrant"
    parameters: { item: "Items.Quantum_Sandwich" }
}

// ============================================================
// CONSOLE COMMANDS (Easter Eggs)
// ============================================================

ConsoleCommand:lilith.sudo_sandwich {
    description: "Orders a quantum sandwich via executive privilege"
    action: "Items.Quantum_Sandwich"
}

ConsoleCommand:lilith.root_equation {
    description: "Solves the root equation"
    action: "UnlockQuickhack"
    parameters: { quickhack: "Quickhack.MSN_Egg_Root" }
}

ConsoleCommand:lilith.witching_hour {
    description: "Checks if it's 3:33 AM"
    action: "TimeCheck"
    parameters: { hour: 3, minute: 33 }
}


