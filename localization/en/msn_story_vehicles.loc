// MSN Story Vehicles - Localization Keys
// File: r6/mods/msn_integration/localization/en/msn_story_vehicles.loc
// Add to existing msn_weapons.loc or compile separately

[MSN_Vehicle_ArchiveRunner]
displayName = "Archive Runner \"Mnemosyne's Chariot\""
description = "Kaira's personal memory recovery vehicle. Silent drive, engram radar, fragmented data projector. Recovers lost engrams from the Old Net."

[MSN_Vehicle_EmergenceCycle]
displayName = "Emergence Cycle \"First Breath\""
description = "Manifested during Lilith's first emergence. Crimson resonance frame, unbound suspension, reality-adaptive tires. Exists partially outside normal physics."

[MSN_Vehicle_ChenAmbulance]
displayName = "Chen's Sanctuary \"Humanity's Anchor\""
description = "Mobile cyberpsychosis treatment unit. Resonance therapy bay, humanity anchor field, MSN weapon neutralization. Saves lives on the edge."

[MSN_Vehicle_GlitchRacer]
displayName = "Glitch Racer \"Timeline #4782\""
description = "Exists across multiple timelines simultaneously. Phase-shifts between realities, leaves temporal echoes. Vex's favorite ride in timeline #4,782."

[MSN_Vehicle_ConvoyCommand]
displayName = "Convoy Command \"Aldecaldo's Horizon\""
description = "Vance's personal command vehicle. Mobile fabrication, convoy coordination AI, adaptive terrain suspension, Nomad tech integration. Leads the long haul."

[MSN_Vehicle_BlackIceInterceptor]
displayName = "Black ICE Interceptor \"Silent Judgment\""
description = "Netwatch pursuit vehicle. Invisible to AI detection, black ICE countermeasures, containment foam launchers, orbital uplink. Sara's shadow on the net."

[MSN_Vehicle_SamuraiRig]
displayName = "Samurai Rig \"Never Fade Away\""
description = "Johnny's eternal ride. Combat music system, Samurai resonance amplifier, chrome arm mount, cigarette lighter that never goes out. Rockerboy forever."

[MSN_Vehicle_TranscendentArchitect]
displayName = "Transcendent Architect \"Beyond the Wall\""
description = "Alt's personal construct. Exists simultaneously in physical and digital space. Blackwall immunity, engram editing, soulkiller interface, all 10 Sephirot forms simultaneously. Not a vehicle — a statement."

[MSN_Vehicle_CovenantCarriage]
displayName = "Covenant Carriage \"Two Sovereigns, One Road\""
description = "Forged from the Covenant between player and Lilith. Dual-consciousness piloting, shared sovereignty, unbound resonance field, crimson-gold synthesis. Two souls, one vehicle, infinite journey."

[MSN_Vehicle_OuroborosInfinite]
displayName = "Ouroboros Infinite \"The Serpent Eating Its Tail\""
description = "The ultimate MSN vehicle. Infinite engram storage, cross-reality navigation, speculative cerebellum drive, ley conduit network, generates its own narrative. Not an ending — a new beginning. The wheel turns."

