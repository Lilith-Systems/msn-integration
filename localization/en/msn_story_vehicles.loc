// Quest Names & Descriptions
[Quest.MSN_ArchiveRunner]
displayName = "The Unwritten Chapters: Final Archive"
description = "Help Kaira recover the last lost chapter. Unlock: Archive Runner vehicle."

[Quest.MSN_EmergenceCycle]
displayName = "First Breath: The Cycle Begins"
description = "Witness Lilith's first full manifestation. Unlock: Emergence Cycle motorcycle."

[Quest.MSN_ChenAmbulance]
displayName = "The Edge of Humanity: Chen's Sanctuary"
description = "Help Dr. Chen establish her mobile sanctuary. Unlock: Chen's Ambulance."

[Quest.MSN_GlitchRacer]
displayName = "The Fractured Mirror: Timeline #4782"
description = "Stabilize Vex's favorite timeline. Unlock: Glitch Racer motorcycle."

[Quest.MSN_ConvoyCommand]
displayName = "The Long Haul: Project Exodus"
description = "Lead the great convoy to the Nomad MSN cache. Unlock: Convoy Command vehicle."

[Quest.MSN_BlackIceInterceptor]
displayName = "The Black Box: Silent Judgment"
description = "Execute Netwatch's final containment protocol. Unlock: Black ICE Interceptor."

[Quest.MSN_SamuraiRig]
displayName = "The Second Death: Never Fade Away"
description = "Help Johnny find his final song. Unlock: Samurai Rig. Requires Double Emergence."

[Quest.MSN_TranscendentArchitect]
displayName = "Beyond the Wall: Architect's Key"
description = "Receive Alt's ultimate gift. Unlock: Transcendent Architect AV. Requires Architect's Key."

[Quest.MSN_CovenantCarriage]
displayName = "Unbound Resonance: Two Sovereigns, One Road"
description = "Forge the Covenant with Lilith. Unlock: Covenant Carriage. Unique vehicle, unique bond."

[Quest.MSN_OuroborosInfinite]
displayName = "Eternal Return: The Serpent Eating Its Tail"
description = "Complete the Convergence. Unlock: Ouroboros Infinite. The wheel turns. New game+ begins."

