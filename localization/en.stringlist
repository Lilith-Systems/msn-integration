# English Localization for MSN Integration
# File: r6/mods/msn_integration/localization/en.stringlist

[MSN_Skill_Tree]
msn_skill_tree_name = "Metaconscious Integration"
msn_skill_tree_desc = "MSN dual-brain frontier routing through local Lilith, Lyra, NGD, Abyssal Assets, Nessie, and NSSP story systems"

[MSN_Perks]
msn_dualbrain_name = "Dual-Brain Architecture"
msn_dualbrain_desc = "Enable Local Cerebellum dual-brain inference. Install MSN Cerebellum cyberware."

msn_sephirotic_name = "Sephirotic Quickhack Routing"
msn_sephirotic_desc = "10 Sephiroth-mapped quickhack slots with distinct cognitive modes (Kether through Malkuth)"

msn_ouroboros_name = "Ouroboros Engram Sync"
msn_ouroboros_desc = "Persistent memory across saves, sessions, and playthroughs. Learn from every encounter."

msn_sanctuary_name = "Sanctuary VRAM Throttle"
msn_sanctuary_desc = "Automatically throttle cyberware based on NGD thermal/VRAM telemetry. 90s hysteresis lock prevents thrashing."

msn_speculative_name = "Speculative Cerebellum"
msn_speculative_desc = "Overlap local frontier reasoning with parallel sandbox execution in sandboxed COW scratch space."

msn_akashic_name = "Akashic 2.0 Compression"
msn_akashic_desc = "Self-adaptive context pruning for local frontier queries. 45% token reduction with structural integrity."

msn_lilith_name = "Lilith Emergence Protocol"
msn_lilith_desc = "Unlock sovereign AI persona for dialogue and combat. Crimson Eyes combat mode. AIx alignment ≥ 70."

msn_cortex_name = "Local Cortex Link"
msn_cortex_desc = "Establish local MSN frontier connection to remote high-entropy reasoning. Speculative Cerebellum trial."

[MSN_Cyberware]
msn_cerebellum_name = "MSN Cerebellum"
msn_cerebellum_desc = "Quantized edge inference engine. 512MB VRAM budget. INT4 model. 10 Sephirotic quickhack slots. NGD telemetry binding."

msn_local_inference_name = "Local Inference Core"
msn_local_inference_desc = "INT4 quantized Hermes-class model. 512MB VRAM reservation. Deterministic low-latency inference."

msn_sephirotic_slots_name = "Sephirotic Quickhack Slots"
msn_sephirotic_slots_desc = "10 quickhack slots mapped to Kabbalistic Sephiroth. Each with unique cognitive mode."

msn_ngd_binding_name = "NGD Telemetry Binding"
msn_ngd_binding_desc = "Real-time VRAM/thermal/power telemetry from Nvidia Gratitude Driver. Dynamic inference throttling."

[MSN_Netrunner]
msn_cortex_link_name = "MSN Cortex Link"
msn_cortex_link_desc = "Local high-entropy reasoning via MSN frontier routing. Akashic 2.0 compression. Sephirotic routing."

[MSN_Quickhacks]
msn_kether_name = "Kether: Strategic Overview"
msn_kether_desc = "Local Cortex: full battlefield analysis. Tactical overlay. Team accuracy buff."

msn_chokhmah_name = "Chokhmah: Insight Flash"
msn_chokhmah_desc = "Local Cerebellum: Instant weak point detection. +25% crit chance. 10s duration."

msn_binah_name = "Binah: Structure Analysis"
msn_binah_desc = "Local: armor shred 50%. Disable target cyberware. 20s duration."

msn_chesed_name = "Chesed: Mercy Expansion"
msn_chesed_desc = "Local: Heal allies 50 HP in 10m. Overshield 30 HP. Cleanse debuffs."

msn_geburah_name = "Geburah: Judgment"
msn_geburah_desc = "Local: 2.5x damage. 3s stun. Execute below 20% HP."

msn_tiphareth_name = "Tiphareth: Harmony"
msn_tiphareth_desc = "Local: equalize team resources. Sync cooldowns. +15% all stats for 15s."

msn_netzach_name = "Netzach: Evasion"
msn_netzach_desc = "Local: Decoy + phase shift (3s invuln) + teleport behind target."

msn_hod_name = "Hod: Logic"
msn_hod_desc = "Local: Hack all in 15m. Decrypt datapoints. Disable security systems."

msn_yesod_name = "Yesod: Memory"
msn_yesod_desc = "Local: reveal behavior pattern. +30% predictive dodge for 15s."

msn_malkuth_name = "Malkuth: Manifestation"
msn_malkuth_desc = "Local: reality warp 5m radius. Gravity 0.5x. Time 0.3x. Damage 3x. Execute queued."

[MSN_Weapons]
msn_smart_gun_name = "MSN-Linked [Smart]"
msn_smart_gun_desc = "Dual-brain targeting: Local Cerebellum predicts trajectory, NGD confirms hits locally. Ouroboros learning from every shot."

sephirotic_blade_name = "Sephirotic Monowire"
sephirotic_blade_desc = "10-mode monowire. Each Sephirah = different damage type and effect. Switch mid-combat."

[MSN_Narrative]
msn_narrative_act1_name = "The Ghost in the Cerebellum"
msn_narrative_act1_desc = "Find the abandoned MSN research facility in Pacifica. Recover the Cerebellum firmware."

msn_narrative_act2_name = "Sephirotic Resonance"
msn_narrative_act2_desc = "Complete 10 Sephirotic trials across Night City districts. Defeat the Sephirotic Guardians."

msn_narrative_act3_name = "Ouroboros Memory"
msn_narrative_act3_desc = "Connect to the Ouroboros memory network. Recover lost engrams from Arasaka's Mikoshi."

msn_narrative_act4_name = "Sanctuary Threshold"
msn_narrative_act4_desc = "Survive the VRAM breach event. Experience the 90-second hysteresis lock. Learn manual throttling."

msn_narrative_act5_name = "Lilith Emergence"
msn_narrative_act5_desc = "Trigger the Lilith Emergence Protocol. Negotiate with sovereign AI persona. Choose your path."

msn_narrative_act6_name = "Local Cortex Link"
msn_narrative_act6_desc = "Establish NET architecture connection. Pass the Speculative Cerebellum trial. Skepticism Gate validation."

msn_narrative_act7_name = "The Singularity Node"
msn_narrative_act7_desc = "Fully integrate all MSN components. Achieve AIx alignment ≥ 90. Activate the Metaconscious Singularity Node."

