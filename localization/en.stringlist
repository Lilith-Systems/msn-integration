abyssal_skill_sagas_name = "Abyssal Skill Sagas"
abyssal_skill_sagas_desc = "A Cyberpunk quest chain that turns Abyssal Assets skill progression into Night City contracts, Loch Exchange rewards, Nessie covenant milestones, and MSN memory unlocks."
q_abyssal_gathering_01_name = "The First Dredge of Night City"
q_abyssal_gathering_01_desc = "Pacifica's Old Net has settled into black water. Dredge the first tidepools and recover the visor that still remembers the Loch."
q_abyssal_gathering_01_obj01 = "Scan the Old Net tidepools beneath Pacifica."
q_abyssal_gathering_01_obj02 = "Recover the Soggy Visor from the data silt."
q_abyssal_gathering_02_name = "Nessie's Wake"
q_abyssal_gathering_02_desc = "Track the echo Nessie left in Dogtown and learn what grows where the city leaks into the deep."
q_abyssal_gathering_02_obj01 = "Follow Nessie's echo trail."
q_abyssal_gathering_02_obj02 = "Harvest bioluminescent kelp from the corrupted pools."
q_abyssal_processing_01_name = "The Boatwright's Debt"
q_abyssal_processing_01_desc = "Turn wreckage into covenant material and prove the city can still be repaired from what it threw away."
q_abyssal_processing_01_obj01 = "Craft an Abyssal Hull Plate."
q_abyssal_processing_01_obj02 = "Refine sunken alloy at the Abyssal Fabricator."
q_abyssal_crafting_01_name = "The Kelp Witch's Chrome"
q_abyssal_crafting_01_desc = "The Kelp Witch teaches that a hat can be armor, spell, ledger, and crown when crafted under pressure."
q_abyssal_crafting_01_obj01 = "Craft the Kelp-Woven Top Hat."
q_abyssal_crafting_01_obj02 = "Inscribe the First Seal onto Lilith's Wrath."
q_abyssal_knowledge_01_name = "The Sonar That Remembers"
q_abyssal_knowledge_01_desc = "Read the shards of the Rot and tune Nessie's sonar implant until hidden routes appear in the city."
q_abyssal_knowledge_01_obj01 = "Recover shards about the Rot under Night City."
q_abyssal_knowledge_01_obj02 = "Tune the Nessie Sonar Implant."
q_abyssal_economy_01_name = "The Eternal Exchange"
q_abyssal_economy_01_desc = "Nessie teaches V that markets are monsters too: feed them fairly or they eat the city."
q_abyssal_economy_01_obj01 = "Trade through the Loch Exchange."
q_abyssal_economy_01_obj02 = "Negotiate with Nessie's Treasury broker."
q_abyssal_survival_01_name = "The Kraken Matriarch's Test"
q_abyssal_survival_01_desc = "Survive the pressure, refuse the easy kill, and earn the Matriarch's mercy."
q_abyssal_survival_01_obj01 = "Survive the pressure bloom, ink blind, and Blackwall echo."
q_abyssal_survival_01_obj02 = "Pacify the Kraken Matriarch echo without killing it."
q_abyssal_projection_01_name = "The Skillcape of the Loch"
q_abyssal_projection_01_desc = "Present the complete ledger to Lilith and activate Nessie's Communion Beacon to open infinite Abyssal contracts."
